# Local configuration for this clone of the demo.
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored — never commit your real values.

# Your GitHub user/org that owns the fork.
GITHUB_OWNER=your-github-username

# Repo name (only change if you renamed your fork).
GITHUB_REPO=grafana-demo-orderservice

# Container image prefix. Default uses GHCR under your owner/repo.
# You can override with a different registry if you publish elsewhere.
GHCR_IMAGE_PREFIX=ghcr.io/${GITHUB_OWNER}/${GITHUB_REPO}

# Your Grafana Cloud host (no protocol). Example: myorg.grafana.net
GRAFANA_HOST=your-stack.grafana.net

# gcx context name (from `gcx config get-contexts`). Used by demo-check.sh
# to read your service account token from ~/.config/gcx/config.yaml.
GCX_CONTEXT=default

# Stable UID for the demo alert rule (kept fixed across re-imports so
# scripts can reference it deterministically). Do not change unless you
# also re-import the alert with a new UID.
ALERT_RULE_UID=order-svc-checkout-latency

# Stable UID for the demo dashboard (matches grafana/dashboard-order-service.json).
DASHBOARD_UID=order-service-n-plus-one-demo
